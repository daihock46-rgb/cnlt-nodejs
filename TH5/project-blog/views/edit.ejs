<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chỉnh sửa: <%= post.title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-white bg-white shadow-sm border-bottom py-3 sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary d-flex align-items-center fs-4" href="/">
                <i class="bi bi-grid-1x2-fill me-2"></i> BÀI THỰC HÀNH SỐ 5 
            </a>
        </div>
    </nav>

    <main class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                
                <div class="d-flex align-items-center mb-4">
                    <a href="/" class="btn btn-white border shadow-sm rounded-circle me-3 custom-btn-hover" style="width: 40px; height: 40px; line-height: 26px;">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <h2 class="fw-bold mb-0 text-dark">Chỉnh sửa bài viết</h2>
                </div>

                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-body p-5 bg-white">
                        <form action="/blogposts/update/<%= post._id %>" method="POST">
                            
                            <div class="mb-4">
                                <label class="form-label fw-semibold text-dark">Tiêu đề bài viết</label>
                                <input type="text" name="title" class="form-control form-control-lg rounded-3 bg-light border-0" value="<%= post.title %>" required>
                            </div>
                            
                            <div class="mb-5">
                                <label class="form-label fw-semibold text-dark">Nội dung</label>
                                <textarea name="body" class="form-control rounded-3 bg-light border-0" rows="10" required><%= post.body %></textarea>
                            </div>
                            
                            <div class="d-flex justify-content-end pt-4 border-top">
                                <a href="/" class="btn btn-white border px-4 me-3 fw-medium text-secondary">Hủy bỏ</a>
                                <button type="submit" class="btn btn-warning text-dark px-5 fw-bold shadow-sm rounded-3">
                                    <i class="bi bi-check2-circle me-2"></i> Cập nhật
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </main>

</body>
</html>