<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bài thực hành số 5</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-white bg-white shadow-sm border-bottom py-3 sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary d-flex align-items-center fs-4" href="/">
                <i class="bi bi-grid-1x2-fill me-2"></i> BÀI THỰC HÀNH SỐ 5 
            </a>
            <div class="d-flex">
                <a href="/blogposts/new" class="btn btn-primary shadow-sm rounded-3 fw-medium px-4">
                    <i class="bi bi-plus-lg me-2"></i> Viết bài mới
                </a>
            </div>
        </div>
    </nav>

    <main class="container py-5">
        <div class="row align-items-center mb-5">
            <div class="col-md-6 mb-3 mb-md-0">
                <h2 class="fw-bold mb-1 text-dark">Tin tức mới hôm nay</h2>
                <p class="text-muted mb-0">Hệ thống báo chí và truyền thông </p>
            </div>
            <div class="col-md-6">
                <form action="/" method="GET" class="d-flex justify-content-md-end">
                    <div class="input-group shadow-sm rounded-3 overflow-hidden" style="max-width: 400px;">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="search" class="form-control border-start-0 ps-0" placeholder="Tìm kiếm bài viết..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
                        <button class="btn btn-dark px-4 fw-medium" type="submit">Tìm</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="row g-4">
            <% if (posts.length > 0) { %>
                <% posts.forEach(post => { %>
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift">
                            <div class="card-body p-4 d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="badge bg-primary-subtle text-primary-custom rounded-pill px-3 py-2 fw-medium">
                                        <i class="bi bi-file-text me-1"></i> Tin tức
                                    </span>
                                    <small class="text-muted">
                                        <i class="bi bi-calendar3 me-1"></i> 
                                        <%= post.createdAt ? post.createdAt.toLocaleDateString('vi-VN') : '03/04/2026' %>
                                    </small>
                                </div>
                                
                                <h5 class="card-title fw-bold text-dark mb-3 line-clamp-2"><%= post.title %></h5>
                                <p class="card-text text-secondary line-clamp-3 mb-4 flex-grow-1">
                                    <%= post.body %>
                                </p>
                                
                                <div class="d-flex justify-content-between align-items-center pt-3 border-top mt-auto">
                                    <a href="/blogposts/<%= post._id %>" class="btn btn-sm btn-light fw-medium px-4 text-dark rounded-3 border">
                                        Xem chi tiết
                                    </a>
                                    <div class="btn-group shadow-sm rounded-3">
                                        <a href="/blogposts/edit/<%= post._id %>" class="btn btn-sm btn-white border px-3 text-secondary custom-btn-hover" title="Sửa">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <a href="/blogposts/delete/<%= post._id %>" class="btn btn-sm btn-white border px-3 text-danger custom-btn-hover" title="Xóa" onclick="return confirm('Bạn có chắc chắn muốn xóa bài viết này?')">
                                            <i class="bi bi-trash3-fill"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5 bg-white rounded-4 shadow-sm mt-3">
                    <i class="bi bi-inboxes display-1 text-muted opacity-25 mb-3 d-block"></i>
                    <h4 class="text-muted fw-bold">Không có bài viết nào</h4>
                    <p class="text-secondary">Hãy bấm "Viết bài mới" để bắt đầu làm đầy blog của bạn.</p>
                </div>
            <% } %>
        </div>
    </main>

    <footer class="py-4 text-center text-muted small mt-auto">
        <p class="mb-0">&copy; 03/04/2026 bài thực hành số 5 by Thanh Ngân.</p>
    </footer>

</body>
</html>